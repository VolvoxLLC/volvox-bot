# Discord OAuth2 credentials (from Discord Developer Portal)
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret

# NextAuth.js secret (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_32

# NextAuth.js URL (the canonical URL of your site)
NEXTAUTH_URL=http://localhost:3000

# Bot API URL (for fetching bot guild list)
# In development, this can be left empty — the dashboard will show all user guilds
# In production, point to the bot's API endpoint
BOT_API_URL=

# Shared secret for authenticating requests to the bot API
# Generate with: openssl rand -base64 32
# Must match the secret configured on the bot API side
BOT_API_SECRET=

# Public Discord Client ID (for the "Add to Server" button on the landing page)
NEXT_PUBLIC_DISCORD_CLIENT_ID=your_discord_client_id

# Optional Sentry monitoring for the dashboard.
# NEXT_PUBLIC_SENTRY_DSN is the browser-safe public DSN for client-side errors.
NEXT_PUBLIC_SENTRY_DSN=

# SENTRY_DSN enables server and edge runtime error capture.
SENTRY_DSN=

# Use matching environment names so browser/server events group together.
# Examples: development, preview, staging, production
SENTRY_ENVIRONMENT=development
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development

# Release identifiers help Sentry group regressions by deploy/build.
# Set both when the dashboard build has a known version or commit SHA.
SENTRY_RELEASE=
NEXT_PUBLIC_SENTRY_RELEASE=

# Trace sampling rates must be between 0 and 1.
# 0 disables tracing; 1 captures every trace. Keep production lower unless volume is tiny.
SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1

# Session Replay is client-only. Text and inputs are masked by Sentry defaults.
# The default here records no normal sessions and samples sessions that hit errors.
NEXT_PUBLIC_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0
NEXT_PUBLIC_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=0.1

# Optional source map upload during CI builds.
# Keep SENTRY_AUTH_TOKEN out of local committed files; CI/secrets manager only.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
