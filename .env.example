# ──────────────────────────────────────────────
# Volvox.Bot — Environment Variables
# Copy to .env and fill in your values:
#   cp .env.example .env
# ──────────────────────────────────────────────

# ── Discord ──────────────────────────────────

# Discord bot token (required)
DISCORD_TOKEN=your_discord_bot_token

# Discord application/client ID for slash command deployment (required)
DISCORD_CLIENT_ID=your_discord_client_id

# Discord OAuth2 client secret (required for web dashboard)
DISCORD_CLIENT_SECRET=your_discord_client_secret

# Discord OAuth2 redirect URI (required for web dashboard)
DISCORD_REDIRECT_URI=http://localhost:3001/api/v1/auth/discord/callback

# Session secret for JWT signing (required for OAuth2 dashboard auth)
# Generate with: openssl rand -base64 32
SESSION_SECRET=your_session_secret

# ── AI Providers ────────────────────────────

# MiniMax API key (required — default triage classify/respond models in config.json route to MiniMax)
MINIMAX_API_KEY=your_minimax_api_key

# Moonshot (Kimi) API key (optional — enable by setting triage.classifyModel/respondModel to a moonshot:* model)
# MOONSHOT_API_KEY=your_moonshot_api_key

# OpenRouter API key (optional — aggregator for MiniMax, Moonshot, and more)
# OPENROUTER_API_KEY=your_openrouter_api_key

# Anthropic API key — reserved for future direct-Anthropic support (see issue #553). Not routed currently.
# ANTHROPIC_API_KEY=your_anthropic_api_key

# ── Additional AI Providers ─────────────────
# Provider metadata (base URL, env key, capabilities) lives in
# `src/data/providers.json`. Every currently-supported provider routes through
# the Vercel AI SDK's `createAnthropic` factory — the provider endpoint MUST
# speak the Anthropic Messages wire protocol.
#
# Add or enable a provider by declaring it in providers.json and setting
# <PROVIDER>_API_KEY in this file (the env var name is specified by each
# provider's `envKey` field). Override the base URL per provider with
# <PROVIDER>_BASE_URL if needed; otherwise the default from providers.json is used.
#
# There is NO cross-provider API-key fallback — missing a provider's credential
# fails at the first generate()/stream() call that routes to it. Startup
# pre-warm errors are swallowed by warmConnection(...).catch(() => {}).

# ── Database ─────────────────────────────────

# PostgreSQL connection string (required)
# For Docker Compose this is overridden automatically; set it for non-Docker use.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/volvoxbot

# PostgreSQL connection pool size (optional — default: 5)
# PG_POOL_SIZE=5

# ── Web Dashboard ────────────────────────────

# NextAuth.js session encryption secret (required for web dashboard)
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret

# NextAuth.js public URL (required for web dashboard)
# Docker Compose overrides this to http://localhost:3000 automatically.
NEXTAUTH_URL=http://localhost:3000

# Bot REST API port (optional — default: 3001)
BOT_API_PORT=3001

# Bot API URL for web dashboard → bot communication (required for web dashboard)
# Docker Compose overrides this when the bot API is available.
BOT_API_URL=http://localhost:3001

# Shared secret for bot ↔ web dashboard API authentication
# Required when running the web dashboard.
BOT_API_SECRET=your_bot_api_secret

# Dashboard URL for CORS origin (required for web dashboard)
DASHBOARD_URL=http://localhost:3000

# Public site URL used for sitemap.xml and robots.txt (optional — default: https://volvox.bot)
NEXT_PUBLIC_SITE_URL=https://volvox.bot

# Discord client ID exposed to browser (required for web dashboard)
NEXT_PUBLIC_DISCORD_CLIENT_ID=your_discord_client_id

# ── Bot Owner / Permissions ───────────────────

# Bot owner Discord user IDs (comma-separated). Bot owners bypass all
# permission checks. This is the sole source of truth for bot owners.
# Find your Discord user ID: User Settings → Advanced → Enable Developer Mode,
# then right-click your name → Copy User ID.
BOT_OWNER_IDS=your_discord_user_id

# ── Session Storage ──────────────────────────

# Redis URL for session storage (optional — falls back to in-memory)
# REDIS_URL=redis://localhost:6379

# ── Optional Integrations ────────────────────

# mem0 API key for user long-term memory (optional — memory features disabled without it)
# Get your API key from https://app.mem0.ai
MEM0_API_KEY=your_mem0_api_key

# ── Webhooks ─────────────────────────────────

# Webhook HMAC signing secret (optional — used to sign X-Webhook-Signature headers).
# Use a separate secret from SESSION_SECRET to maintain key separation.
# Generate with: openssl rand -base64 32
# WEBHOOK_SECRET=your_webhook_signing_secret

# URL to POST when global config changes (optional — fire-and-forget, 5s timeout)
# CONFIG_CHANGE_WEBHOOK_URL=https://example.com/hooks/config-changed

# URL to POST when guild config changes (optional — notifies dashboard, 5s timeout)
# DASHBOARD_WEBHOOK_URL=https://example.com/hooks/dashboard-config-changed

# ── Sentry (Error Monitoring) ────────────────

# Sentry DSN — enables error tracking and alerting (optional)
# Get yours at https://sentry.io → Create Project → Node.js
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Sentry environment name (optional — default: NODE_ENV or 'production')
# SENTRY_ENVIRONMENT=production

# Sentry release identifier for server-side event grouping (optional)
# SENTRY_RELEASE=volvox-bot@0.1.0

# Send default request/user PII to Sentry after local scrubbers run (optional — default: false)
# SENTRY_SEND_DEFAULT_PII=false

# Sentry performance sampling rate 0-1 (optional — default: 0.1 = 10%)
# SENTRY_TRACES_RATE=0.1

# Dashboard browser Sentry DSN (optional — public DSN for Next.js client errors)
# NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Dashboard browser Sentry environment/release (optional)
# NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
# NEXT_PUBLIC_SENTRY_RELEASE=volvox-dashboard@0.1.0

# Dashboard browser PII capture after local scrubbers run (optional — default: false)
# NEXT_PUBLIC_SENTRY_SEND_DEFAULT_PII=false

# Dashboard Sentry performance/replay sampling 0-1 (optional)
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
# NEXT_PUBLIC_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0
# NEXT_PUBLIC_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=0.1

# Dashboard source map upload in CI only (optional)
# SENTRY_ORG=your_sentry_org
# SENTRY_PROJECT=your_sentry_project
# SENTRY_AUTH_TOKEN=sntrys_your_token

# ── Amplitude (Analytics and Non-Error Logs) ─

# Bot/server Amplitude API key — enables sanitized info/warn log analytics (optional)
# AMPLITUDE_API_KEY=your_amplitude_api_key

# Amplitude data residency for bot/server events: US or EU (optional — default: US)
# AMPLITUDE_SERVER_ZONE=US

# Dashboard browser Amplitude API key — enables page-view and custom UI analytics (optional)
# This is a public browser key; do not put secret keys in NEXT_PUBLIC_* variables.
# NEXT_PUBLIC_AMPLITUDE_API_KEY=your_public_amplitude_api_key

# Dashboard Amplitude data residency: US or EU (optional — default: US)
# NEXT_PUBLIC_AMPLITUDE_SERVER_ZONE=US

# Dashboard Amplitude autocapture (optional — default: false)
# false keeps tracking to explicit app events; true enables limited page/session/attribution capture.
# NEXT_PUBLIC_AMPLITUDE_AUTOCAPTURE=false

# ── Runtime ───────────────────────────────────

# Node environment (optional — default: production)
# NODE_ENV=production

# Express request body size limit (optional — default: 100kb)
# API_BODY_LIMIT=100kb

# Disable TLS for local PostgreSQL (optional — default: false)
# DATABASE_SSL=false

# ── Logging ──────────────────────────────────

# Logging level (optional: debug, info, warn, error — default: info)
LOG_LEVEL=info
